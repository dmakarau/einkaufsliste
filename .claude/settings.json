{
  "permissions": {
    "allow": [
      "Bash(flutter analyze:*)",
      "Bash(flutter --version:*)",
      "Bash(flutter pub get:*)",
      "Bash(flutter pub outdated:*)",
      "Bash(flutter gen-l10n:*)",
      "Bash(dart format lib/:*)",
      "Bash(dart run build_runner build:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(supabase db diff:*)",
      "Bash(supabase db pull:*)",
      "Bash(supabase db dump:*)",
      "Bash(supabase migration list:*)",
      "Bash(supabase migration repair:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-supabase-drift.sh"
          }
        ]
      }
    ]
  }
}
